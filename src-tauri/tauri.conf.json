{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clothing Quality Inspection",
  "version": "0.1.1",
  "identifier": "com.clothesqa.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Clothing Quality Inspection", "width": 1280, "height": 820, "minWidth": 900, "minHeight": 650 }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../template-1.xlsx", "../template-2.xlsx"],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "languages": ["English"],
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
